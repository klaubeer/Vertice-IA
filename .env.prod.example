# Copie para .env.prod e preencha os valores reais
# NUNCA commitar o .env.prod no git

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# LangFuse
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://langfuse:3000

# Segredos internos do Langfuse (gere com: openssl rand -hex 32)
LANGFUSE_SECRET=troque-por-segredo-forte-32-chars
LANGFUSE_SALT=troque-por-salt-forte-32-chars
LANGFUSE_DB_PASSWORD=troque-por-senha-forte
